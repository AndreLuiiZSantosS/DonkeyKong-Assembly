# =====================================================================
# SUB-ROTINAS BASE (Retângulos, Pixels e Escadas)
# =====================================================================
draw_rect:
        move $t5, $a1
        move $t8, $a3
rect_y_loop:
        move $t6, $a0
        move $t7, $a2
rect_x_loop:
        lui $t9, 0x1001
        sll $t0, $t5, 9
        add $t9, $t9, $t0
        sll $t0, $t6, 2
        add $t9, $t9, $t0
        sw $t4, 0($t9)
        addi $t6, $t6, 1
        addi $t7, $t7, -1
        bgtz $t7, rect_x_loop
        addi $t5, $t5, 1
        addi $t8, $t8, -1
        bgtz $t8, rect_y_loop
        jr $31

draw_pixel:
        lui $t9, 0x1001
        sll $t0, $a1, 9
        add $t9, $t9, $t0
        sll $t0, $a0, 2
        add $t9, $t9, $t0
        sw $t4, 0($t9)
        jr $31

draw_escada:
        li $t4, 0x00aaaaaa
        move $t5, $a1
        move $t6, $a2
        li $t7, 0
escada_loop:
        lui $t9, 0x1001
        sll $t0, $t5, 9
        add $t9, $t9, $t0
        sll $t0, $a0, 2
        add $t9, $t9, $t0
        sw $t4, 0($t9)
        sw $t4, 8($t9)
        andi $t0, $t7, 1
        bnez $t0, skip_degrau
        sw $t4, 4($t9)
skip_degrau:
        addi $t5, $t5, 1
        addi $t7, $t7, 1
        addi $t6, $t6, -1
        bgtz $t6, escada_loop
        jr $31

