main:
        # ==================================================
        # 1. INICIALIZAÇÃO DE REGISTRADORES BASE (Cores DK)
        # ==================================================
        li $s0, 0x008b4513       # Marrom (Pelagem)
        li $s1, 0x00ffcc99       # Pele (Rosto/Pés)
        li $s2, 0x00ff0000       # Vermelho (Gravata)
        li $s3, 0x00000000       # Preto (Olhos/Boca)

        # ==================================================
        # 2. DESENHO DO CENÁRIO (Background, Prédios e Céu)
        # ==================================================
        jal draw_background
        jal draw_platforms
        jal draw_ladders

        # ==================================================
        # 3. LOOP PRINCIPAL DO JOGO (Animação + Física)
        # ==================================================
main_loop:
        # Posição do Donkey Kong (Centro do 5o Andar: X=50, Y=8)
        # Endereço: Base + (8 * 512) + (50 * 4) = 4096 + 200 = 4296
        lui $a3, 0x1001
        addi $a3, $a3, 4296

        # --- Frame 1: DK olha para a esquerda (Limpa o loop anterior) ---
        jal draw_dk_esquerda
        
        li $v0, 32
        li $a0, 500              # Pausa de meio segundo
        syscall

        # --- Frame 2: DK estica o braço e gera o barril na mão ---
        jal draw_dk_pegar_esq
        
        li $v0, 32
        li $a0, 500
        syscall

        # --- Frame 3: DK vira para a direita e SOLTA o barril ---
        jal draw_dk_jogar_dir

        # ==================================================
        # 4. MOTOR DE FÍSICA DO BARRIL (Z-Path da Fase 2)
        # ==================================================
        
        # --- ANIMAÇÃO DE QUEDA DA MÃO PARA O 5o ANDAR ---
        li $s6, 62               # X Inicial (Mão direita do DK)
        li $s7, 2                # Y Inicial (Acima da cabeça)
loop_drop:
        move $a1, $s6
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 20               # Queda rápida da mão
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s7, $s7, 1
        blt $s7, 5, loop_drop    # Cai até o piso do 5o andar (Y=5)

        # --- 5o ANDAR: ROLAR PARA A DIREITA ---
loop_rola_dir_5:
        move $a1, $s6
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 25
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s6, $s6, 1
        ble $s6, 81, loop_rola_dir_5  # Rola até o buraco da direita (X=82)

        # --- CAIR PARA O 4o ANDAR ---
loop_cai_dir_4:
        move $a1, $s6            # X travado em 82
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 15
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s7, $s7, 1
        blt $s7, 18, loop_cai_dir_4   # Cai até o piso do 4o andar (Y=18)

        # --- 4o ANDAR: ROLAR PARA A ESQUERDA ---
loop_rola_esq_4:
        move $a1, $s6
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 25
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s6, $s6, -1
        bge $s6, 20, loop_rola_esq_4  # Rola até o buraco da esquerda (X=19)

        # --- CAIR PARA O 3o ANDAR ---
loop_cai_esq_3:
        move $a1, $s6            # X travado em 19
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 15
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s7, $s7, 1
        blt $s7, 31, loop_cai_esq_3   # Cai até o piso do 3o andar (Y=31)

        # --- 3o ANDAR: ROLAR PARA A DIREITA ---
loop_rola_dir_3:
        move $a1, $s6
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 25
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s6, $s6, 1
        ble $s6, 81, loop_rola_dir_3  # Rola até o buraco da direita (X=82)

        # --- CAIR PARA O 2o ANDAR ---
loop_cai_dir_2:
        move $a1, $s6            # X travado em 82
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 15
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s7, $s7, 1
        blt $s7, 43, loop_cai_dir_2   # Cai até o piso do 2o andar (Y=43)

        # --- 2o ANDAR: ROLAR PARA A ESQUERDA ---
loop_rola_esq_2:
        move $a1, $s6
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 25
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s6, $s6, -1
        bge $s6, 27, loop_rola_esq_2  # Rola até o buraco da esquerda (X=26)

        # --- CAIR PARA O 1o ANDAR (TÉRREO) ---
loop_cai_esq_1:
        move $a1, $s6            # X travado em 26
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 15
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s7, $s7, 1
        blt $s7, 57, loop_cai_esq_1   # Cai até o Térreo (Y=57)

        # --- TÉRREO: ROLAR PARA A DIREITA ATÉ SUMIR ---
loop_rola_dir_1:
        move $a1, $s6
        move $a2, $s7
        jal draw_barril_xy
        
        li $v0, 32
        li $a0, 25
        syscall
        
        move $a1, $s6
        move $a2, $s7
        jal erase_barril_xy
        
        addi $s6, $s6, 1
        ble $s6, 128, loop_rola_dir_1 # Rola até sair da tela

        # Retorna para o início do jogo (Loop Infinito)
        j main_loop


