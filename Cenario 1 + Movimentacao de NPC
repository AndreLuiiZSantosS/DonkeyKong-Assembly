main:
        lui $s5, 0x1001
        addi $s5, $s5, 4152

        # ==================================================
        # 1. CÉU NOTURNO (Degradê)
        # ==================================================
        li $a0, 0
        li $a1, 0
        li $a2, 128
        li $a3, 21
        li $t4, 0x0008081a
        jal draw_rect

        li $a0, 0
        li $a1, 21
        li $a2, 128
        li $a3, 20
        li $t4, 0x000d0d2b
        jal draw_rect

        li $a0, 0
        li $a1, 41
        li $a2, 128
        li $a3, 23 
        li $t4, 0x0012123d
        jal draw_rect

        # ==================================================
        # 2. ESTRELAS E LUA CHEIA
        # ==================================================
        li $t4, 0x00ffffff
        li $a0, 5
        li $a1, 5
        jal draw_pixel
        
        li $a0, 18
        li $a1, 12
        jal draw_pixel
        
        li $a0, 30
        li $a1, 4
        jal draw_pixel
        
        li $a0, 45
        li $a1, 15
        jal draw_pixel
        
        li $a0, 80
        li $a1, 6
        jal draw_pixel
        
        li $a0, 95
        li $a1, 18
        jal draw_pixel
        
        li $a0, 115
        li $a1, 8
        jal draw_pixel

        li $t4, 0x00fcfcda
        li $a0, 99
        li $a1, 4
        li $a2, 5
        li $a3, 1
        jal draw_rect
        
        li $a0, 98
        li $a1, 5
        li $a2, 7
        li $a3, 4
        jal draw_rect
        
        li $a0, 99
        li $a1, 9
        li $a2, 5
        li $a3, 1
        jal draw_rect

        # ==================================================
        # 3. PRÉDIOS - CAMADA 1 (Fundo Silhuetas)
        # ==================================================
        li $t4, 0x001a1a2e
        li $a0, 10
        li $a1, 20
        li $a2, 20
        li $a3, 44
        jal draw_rect
        
        li $a0, 50
        li $a1, 15
        li $a2, 25
        li $a3, 49
        jal draw_rect
        
        li $a0, 90
        li $a1, 25
        li $a2, 30
        li $a3, 39
        jal draw_rect

        # ==================================================
        # 4. PRÉDIOS - CAMADA 2 (Frente e Detalhes)
        # ==================================================
        li $t4, 0x00252542
        li $a0, 2
        li $a1, 30
        li $a2, 20
        li $a3, 34
        jal draw_rect
        
        li $t4, 0x00ff3366
        li $a0, 12
        li $a1, 22
        li $a2, 1
        li $a3, 8
        jal draw_rect
        
        li $t4, 0x002b2d42
        li $a0, 30
        li $a1, 18
        li $a2, 25
        li $a3, 46
        jal draw_rect
        
        li $a0, 35
        li $a1, 15
        li $a2, 15
        li $a3, 3
        jal draw_rect
        
        li $t4, 0x00ff0000
        li $a0, 42
        li $a1, 14
        jal draw_pixel

        li $t4, 0x001f2030
        li $a0, 65
        li $a1, 10
        li $a2, 23
        li $a3, 54
        jal draw_rect
        
        li $t4, 0x00ffffff
        li $a0, 76
        li $a1, 2
        li $a2, 1
        li $a3, 8
        jal draw_rect

        li $t4, 0x00302b3a
        li $a0, 98
        li $a1, 35
        li $a2, 27
        li $a3, 29
        jal draw_rect

        # ==================================================
        # 5. JANELAS E LUZES
        # ==================================================
        li $t2, 34
loop_winA_y:
        li $t3, 6
loop_winA_x:
        move $a0, $t3
        move $a1, $t2
        li $a2, 2
        li $a3, 1
        li $t4, 0x00ffcc00
        jal draw_rect
        addi $t3, $t3, 4
        ble $t3, 17, loop_winA_x
        addi $t2, $t2, 4
        ble $t2, 63, loop_winA_y

        li $t2, 14
loop_winC_y:
        li $t3, 72
loop_winC_x:
        move $a0, $t3
        move $a1, $t2
        li $a2, 2
        li $a3, 3
        li $t4, 0x00ff9900
        jal draw_rect
        addi $t3, $t3, 3
        ble $t3, 81, loop_winC_x
        addi $t2, $t2, 6
        ble $t2, 63, loop_winC_y

        li $t2, 40
loop_winD_y:
        li $t3, 102
loop_winD_x:
        move $a0, $t3
        move $a1, $t2
        li $a2, 3
        li $a3, 1
        li $t4, 0x00ffffcc
        jal draw_rect
        addi $t3, $t3, 6
        ble $t3, 119, loop_winD_x
        addi $t2, $t2, 5
        ble $t2, 63, loop_winD_y

        li $t2, 15
loop_neonC:
        li $a0, 67
        move $a1, $t2
        li $a2, 1
        li $a3, 2
        li $t4, 0x0000ffcc
        jal draw_rect
        addi $t2, $t2, 3
        ble $t2, 34, loop_neonC

        li $t2, 22               
loop_winB_y:
        li $t3, 34               
loop_winB_x:
        add $t0, $t3, $t2        
        li $t1, 5
        div $t0, $t1             
        mfhi $t8                 
        beqz $t8, skip_winB      
        
        move $a0, $t3
        move $a1, $t2
        li $t4, 0x0088ccff       
        jal draw_pixel           
        
skip_winB:
        addi $t3, $t3, 2         
        ble $t3, 50, loop_winB_x
        addi $t2, $t2, 3         
        ble $t2, 63, loop_winB_y

        # ==================================================
        # 6. PLATAFORMAS VERMELHAS
        # ==================================================
        li $t4, 0x00ff0000
        
        li $a0, 0
        li $a1, 62
        li $a2, 128
        li $a3, 2
        jal draw_rect
        
        li $a0, 0
        li $a1, 48
        li $a2, 103
        li $a3, 2
        jal draw_rect
        
        li $a0, 25
        li $a1, 36
        li $a2, 103
        li $a3, 2
        jal draw_rect
        
        li $a0, 0
        li $a1, 23
        li $a2, 103
        li $a3, 2
        jal draw_rect
        
        li $a0, 25
        li $a1, 10
        li $a2, 103
        li $a3, 2
        jal draw_rect

        # ==================================================
        # 7. ESCADAS
        # ==================================================
        jal draw_ladders

        # ==================================================
        # 8. BARRIS ESTÁTICOS (PILHA NO 4º ANDAR)
        # ==================================================
        li $a0, 4
        li $a1, 20
        jal draw_barril_cenario

        li $a0, 4
        li $a1, 17
        jal draw_barril_cenario

        li $a0, 4
        li $a1, 14
        jal draw_barril_cenario

        # ==================================================
        # 8.1 PRINCESA NO 5o ANDAR
        # ==================================================
        jal save_princesa_area
        jal draw_princesa

        # ==================================================
        # INICIALIZAÇÃO DE CORES DO DONKEY KONG (PÓS-CENÁRIO)
        # ==================================================
        li $s0, 0x008b4513
        li $s1, 0x00ffcc99
        li $s2, 0x00ff0000
        li $s3, 0x00000000

        jal save_dk_area

        # ==================================================
        # 9. LOOP PRINCIPAL (ANIMAÇÃO DONKEY KONG + FÍSICA BARRIL)
        # ==================================================
loop_dk_animacao:
        jal clear_dk_area
        jal save_dk_area
        jal draw_dk_frente
        jal redraw_pilha_barris
        li $a0, 240
        jal sleep_princesa

        # Donkey vira para a esquerda antes de ir ate a pilha.
        jal clear_dk_area
        jal save_dk_area
        jal draw_dk_andar_esq
        jal redraw_pilha_barris
        li $a0, 220
        jal sleep_princesa

        jal clear_dk_area
        addi $s5, $s5, -8       # passo 1: 2 pixels para esquerda
        jal save_dk_area
        jal draw_dk_andar_esq
        jal redraw_pilha_barris
        li $a0, 230
        jal sleep_princesa

        jal clear_dk_area
        addi $s5, $s5, -8       # passo 2: mais 2 pixels para esquerda
        jal save_dk_area
        jal draw_dk_pegar_esq
        jal redraw_pilha_barris
        li $a0, 300
        jal sleep_princesa

        # Com o barril novo na mao, vira para a direita.
        jal clear_dk_area
        jal save_dk_area
        jal draw_dk_com_barril_dir
        jal redraw_pilha_barris
        li $a0, 260
        jal sleep_princesa

        # Volta para a posicao inicial em dois passos, carregando o barril.
        jal clear_dk_area
        addi $s5, $s5, 8
        jal save_dk_area
        jal draw_dk_com_barril_dir
        jal redraw_pilha_barris
        li $a0, 230
        jal sleep_princesa

        jal clear_dk_area
        addi $s5, $s5, 8        # volta posicao original
        jal save_dk_area
        jal draw_dk_com_barril_dir
        jal redraw_pilha_barris
        li $a0, 260
        jal sleep_princesa

        # Solta o barril e olha para frente antes de repetir o ciclo.
        jal clear_dk_area
        jal save_dk_area
        jal draw_dk_soltar_dir
        jal redraw_pilha_barris
        li $a0, 230
        jal sleep_princesa

        jal clear_dk_area
        jal save_dk_area
        jal draw_dk_frente
        jal redraw_pilha_barris
        li $a0, 220
        jal sleep_princesa
        
        # INÍCIO DA ROLAGEM DO BARRIL
        li $s6, 20       
        li $s7, 20          

roll_right_4:
        jal anim_barril_step
        addi $s6, $s6, 1
        ble $s6, 104, roll_right_4

drop_4_3:
        jal anim_barril_step
        addi $s7, $s7, 1
        ble $s7, 33, drop_4_3

roll_left_3:
        jal anim_barril_step
        addi $s6, $s6, -1
        bge $s6, 20, roll_left_3

drop_3_2:
        jal anim_barril_step
        addi $s7, $s7, 1
        ble $s7, 45, drop_3_2

roll_right_2:
        jal anim_barril_step
        addi $s6, $s6, 1
        ble $s6, 104, roll_right_2

drop_2_1:
        jal anim_barril_step
        addi $s7, $s7, 1
        ble $s7, 59, drop_2_1

roll_left_1:
        jal anim_barril_step
        addi $s6, $s6, -1
        bge $s6, 0, roll_left_1

        j loop_dk_animacao

        # ==================================================
        # ENCERRAMENTO 
        # ==================================================
        li $v0, 10
        syscall

# =====================================================================
# SUB-ROTINAS DE DESENHO E ANIMAÇÃO
# =====================================================================
anim_barril_step:
        addi $sp, $sp, -4
        sw $ra, 0($sp)
        
        move $a0, $s6
        move $a1, $s7
        li $a2, 3
        li $a3, 3
        la $t4, buffer_bg_barril
        jal save_bg
        
        move $a0, $s6
        move $a1, $s7
        jal draw_barril_cenario
        
        li $v0, 32
        li $a0, 15
        syscall
        
        move $a0, $s6
        move $a1, $s7
        li $a2, 3
        li $a3, 3
        la $t4, buffer_bg_barril
        jal restore_bg
        jal anim_princesa_step
        
        lw $ra, 0($sp)
        addi $sp, $sp, 4
        jr $ra

draw_rect:
        move $t5, $a1
        move $t8, $a3
rect_y_loop:
        move $t6, $a0
        move $t7, $a2
rect_x_loop:
        lui $t9, 0x1001
        sll $t0, $t5, 9
        add $t9, $t9, $t0
        sll $t0, $t6, 2
        add $t9, $t9, $t0
        sw $t4, 0($t9)
        addi $t6, $t6, 1
        addi $t7, $t7, -1
        bgtz $t7, rect_x_loop
        addi $t5, $t5, 1
        addi $t8, $t8, -1
        bgtz $t8, rect_y_loop
        jr $31

draw_pixel:
        lui $t9, 0x1001
        sll $t0, $a1, 9
        add $t9, $t9, $t0
        sll $t0, $a0, 2
        add $t9, $t9, $t0
        sw $t4, 0($t9)
        jr $31

draw_barril_cenario:
        lui $t9, 0x1001
        sll $t0, $a1, 9
        add $t9, $t9, $t0
        sll $t0, $a0, 2
        add $t9, $t9, $t0
        
        # Cores ajustadas para Marrom
        li $t0, 0x008b4513
        li $t1, 0x00a0522d
        li $t2, 0x00d2691e

        sw $t0, 0($t9)
        sw $t0, 4($t9)
        sw $t0, 8($t9)

        sw $t1, 512($t9)
        sw $t2, 516($t9)
        sw $t1, 520($t9)

        sw $t0, 1024($t9)
        sw $t0, 1028($t9)
        sw $t0, 1032($t9)

        jr $31

draw_ladders:
        addi $sp, $sp, -4
        sw $ra, 0($sp)

        li $a0, 90      
        li $a1, 48
        li $a2, 14
        jal draw_escada
        
