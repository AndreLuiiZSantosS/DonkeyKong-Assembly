        li $a1, 10
        li $a2, 13
        jal draw_escada
        
        lw $ra, 0($sp)
        addi $sp, $sp, 4
        jr $ra

draw_escada:
        li $t4, 0x00aaaaaa
        move $t5, $a1
        move $t6, $a2
        li $t7, 0
escada_loop:
        lui $t9, 0x1001
        sll $t0, $t5, 9
        add $t9, $t9, $t0
        sll $t0, $a0, 2
        add $t9, $t9, $t0
        sw $t4, 0($t9)
        sw $t4, 8($t9)
        andi $t0, $t7, 1
        bnez $t0, skip_degrau
        sw $t4, 4($t9)
skip_degrau:
        addi $t5, $t5, 1
        addi $t7, $t7, 1
        addi $t6, $t6, -1
        bgtz $t6, escada_loop
        jr $31

check_fisica_escada:
        li $v0, 0                
        blt $a0, 35, skip_col_esq
        bgt $a0, 37, skip_col_esq
        li $v0, 1
        jr $31
skip_col_esq:
        blt $a0, 90, skip_col_dir
        bgt $a0, 92, skip_col_dir
        li $v0, 1
        jr $31
